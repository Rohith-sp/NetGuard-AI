# NetGuard AI - Environment Configuration
# Copy this file to .env and fill in your values

# API Key for protecting /attacker/mode and /simulate endpoints
# CHANGE THIS IN PRODUCTION!
NETGUARD_API_KEY=changeme-dev-key

# MQTT Broker Configuration
# For production, use a private broker with authentication and TLS
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false
MQTT_CA_CERTS=

# LLM API Key for RAG chatbot (Groq)
GROQ_API_KEY=your_groq_api_key_here